# Neon Postgres (Vercel-recommended database)
# Get your connection string from https://neon.tech or Vercel dashboard
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Platform Selection — Choose between GitHub and GitLab
# Options: github | gitlab (default: github)
# PLATFORM=github

# GitHub Integration — Event-Driven Trigger System (Issue #43)
# Required: GitHub personal access token (needs repo webhook admin scope)
# GITHUB_TOKEN=github_pat_...
# Optional: Shared HMAC secret for verifying incoming webhook payloads
# GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# GitHub Polling Adapter (Issue #45) — Alternative to webhooks for local development
# Optional: Enable polling on startup (default: false)
# GITHUB_POLLING_ENABLED=false
# Optional: Polling interval in seconds (default: 30, minimum: 10)
# GITHUB_POLLING_INTERVAL=30

# GitLab Integration — Event-Driven Trigger System
# Required when PLATFORM=gitlab: GitLab personal access token (needs api, read_api, read_repository scopes)
# GITLAB_TOKEN=glpat-...
# Optional: Custom GitLab instance URL (default: https://gitlab.com)
# GITLAB_URL=https://gitlab.com
# Optional: Shared secret for verifying incoming webhook payloads
# GITLAB_WEBHOOK_SECRET=your-webhook-secret-here

# GitLab Polling Adapter — Alternative to webhooks for local development
# Optional: Enable polling on startup (default: false)
# GITLAB_POLLING_ENABLED=false
# Optional: Polling interval in seconds (default: 30, minimum: 10)
# GITLAB_POLLING_INTERVAL=30

# Claude Code SDK Configuration (for Vercel/serverless environments)
# Required: API authentication token
ANTHROPIC_AUTH_TOKEN=your-token-here
# Optional: Custom API endpoint (e.g., BigModel's Anthropic-compatible API)
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# Optional: Request timeout in milliseconds (default: 600000)
# API_TIMEOUT_MS=3000000
# Optional: Disable non-essential traffic for Claude Code
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Model configuration (optional, defaults to Claude models)
# ANTHROPIC_MODEL=glm-5.1
# ANTHROPIC_SMALL_FAST_MODEL=glm-5.1
# ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5.1
# ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.1
# ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-5.1

# Development Configuration
# Optional: Additional allowed dev origins for Next.js (comma-separated)
# Useful when accessing the dev server from other devices on your network
# Example: ROUTA_ALLOWED_DEV_ORIGINS=192.168.1.210,10.0.0.5
# ROUTA_ALLOWED_DEV_ORIGINS=

# Optional: Root directory for git worktrees (defaults to ~/.routa/workspace)
# Set this to a path with enough disk space, especially on Windows where C: may be limited
# Example: ROUTA_WORKTREE_ROOT=E:\.routa\worktrees
# ROUTA_WORKTREE_ROOT=

# Performance Tuning
# Optional: Max event listeners on the global process object (default: 20).
# Increase if you see MaxListenersExceededWarning with many concurrent agent sessions.
# ROUTA_MAX_LISTENERS=20
# Optional: Comma-separated retry delays in ms for API 429 rate-limit errors during
# kanban automation. Default: 30000,60000,120000 (3 retries: 30s, 60s, 120s).
# Set to empty to disable retries.
# ROUTA_RATE_LIMIT_RETRY_DELAYS=30000,60000,120000
# Optional: Store dedup proxy — set to "0" to disable Promise coalescing for store reads.
# ROUTA_STORE_DEDUP=1
# Optional: Store slow query threshold in ms (default: 200). Requires ROUTA_STORE_TIMING=1.
# ROUTA_STORE_SLOW_THRESHOLD_MS=200
# Optional: Enable store timing instrumentation. Set to "1" to log slow store operations.
# ROUTA_STORE_TIMING=0
# Optional: Max consecutive session creation failures before circuit breaker activates (default: 3).
# Once a card exceeds this limit, the watchdog stops retrying session creation for that card.
# ROUTA_SESSION_RETRY_LIMIT=3
# Optional: Cooldown period in ms before circuit-broken cards can retry (default: 300000 = 5 min).
# After cooldown, the failure count resets and the lane scanner re-triggers the card.
# ROUTA_SESSION_RETRY_RESET_MS=300000
# Optional: Max PR auto-creation attempts per task before giving up (default: 3).
# ROUTA_PR_RETRY_LIMIT=3
