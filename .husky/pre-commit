# Pre-commit hook: Run quick lint check
# Full checks are done in pre-push

# Skip if SKIP_HOOKS is set (for emergency commits)
if [ -n "$SKIP_HOOKS" ]; then
  echo "⚠️  SKIP_HOOKS is set, skipping pre-commit checks"
  exit 0
fi

# Fail early if staged source files grow beyond the AI refactor threshold.
PYTHONPATH=tools/entrix python3 -m entrix hook file-length \
  --config tools/entrix/file_budgets.pre_commit.json \
  --staged-only \
  --strict-limit

# Run lint only (fast check)
npm run lint
